{
  "name": "nextjs_tailwind_shadcn_ts",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": ">=20.19 <21"
  },
  "scripts": {
    "dev": "next dev -p 3000 2>&1 | tee dev.log",
    "build": "npm run build:client && next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "prisma migrate deploy && NODE_ENV=production node .next/standalone/server.js",
    "postinstall": "prisma generate",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy":"prisma migrate deploy",
    "db:sync":"prisma db push",
    "db:reset": "prisma migrate reset",
    "test": "vitest run",
    "test:smoke":"node scripts/smoke-e2e.mjs",
    "test:watch": "vitest",
    "build:tactics": "node scripts/build-tactics.mjs",
    "build:field":"node scripts/build-field-geometry.mjs",
    "build:client":"npm run build:field && npm run build:tactics"
    ,"check:budget":"node scripts/check-client-budget.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "@radix-ui/react-toast": "^1.2.14",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.2",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "next-auth": "^4.24.11",
    "prisma": "^6.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^22.2.2",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/expect": "^4.1.9",
    "bun-types": "^1.3.4",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "overrides":{"postcss":"8.5.15","uuid":"11.1.1"}
}
